<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="../styles/style.css">
    <link rel="stylesheet" href="../styles/style_images.css">
    <title>EJS Gallery</title>
</head>
<body>

    <header>
        <h1>EJS Movie Gallery</h1>
    </header>

    <nav class="nav-menu" aria-label="Main navigation"> <!-- dodati obilježja za ARIA-->
		<ul>
			<li><a href="../index.html">Home</a></li>
			<li><a href="../pages/charts.html">Charts</a></li>
			<li><a href="../pages/images.html">Gallery</a></li>
			<li><a href="../images">Gallery v2</a></li>
		</ul>
	</nav>

    <main class="image-container">
        <h1>Gallery</h1>

        <section class="gallery">
        <% images.forEach((image, index) => { %>
            <figure class="magnific-img">
                <a href="#img<%= index %>"><img src="<%= image.url %>" alt="<%= image.title %>"></a>
            
            </figure>
        <% }); %>
        </section>
    </main>

    <% images.forEach((image, index) => { %>
    <div class="lightbox-target" id="img<%= index %>">
        <img src="<%= image.url %>" alt="<%= image.title %>">
        <a class="lightbox-close" href="#">x</a>
    </div>
    <% }); %>

    <footer>
	<p>&copy; 2026. Web Programming. All rights reserved.</p>
	</footer>
</body>
</html>